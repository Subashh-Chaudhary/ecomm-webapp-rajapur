generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS
// ==========================================

enum Role {
  superadmin
  admin
  customer
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

// ==========================================
// STORE CONFIGURATION
// ==========================================

model StoreProfile {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @unique @db.VarChar(255)
  slug         String   @unique @db.VarChar(255)
  description  String?  @db.Text
  slogan       String?  @db.VarChar(255)
  logo_id      String?  @db.Uuid
  favicon_url  String?  @db.VarChar(500)
  email        String?  @db.VarChar(255)
  phone        String?  @db.VarChar(50)
  address      String?  @db.Text
  latitude     Decimal? @db.Decimal(10, 8)
  longitude    Decimal? @db.Decimal(11, 8)
  social_links Json?    @db.Json
  created_at   DateTime @default(now()) @db.Timestamptz
  updated_at   DateTime @updatedAt @db.Timestamptz

  logo Media? @relation("StoreProfileLogo", fields: [logo_id], references: [id])

  @@map("store_profile")
}

// ==========================================
// AUTHENTICATION & USERS
// ==========================================

model User {
  id                String    @id @default(uuid()) @db.Uuid
  email             String    @unique @db.VarChar(255)
  password_hash     String    @db.VarChar(255)
  full_name         String    @db.VarChar(100)
  phone             String?   @db.VarChar(50)
  role              Role      @default(customer)
  is_active         Boolean   @default(true)
  email_verified_at DateTime? @db.Timestamptz
  created_at        DateTime  @default(now()) @db.Timestamptz
  updated_at        DateTime  @updatedAt @db.Timestamptz

  addresses       Address[]
  orders          Order[]
  statusHistories OrderStatusHistory[]
  carts           Cart[]
  wishlists       Wishlist[]
  media           Media[]              @relation("UserMedia")

  @@map("users")
}

model Address {
  id            String   @id @default(uuid()) @db.Uuid
  user_id       String   @db.Uuid
  label         String?  @db.VarChar(100)
  full_name     String   @db.VarChar(255)
  phone         String   @db.VarChar(50)
  address_line1 String   @db.VarChar(255)
  address_line2 String?  @db.VarChar(255)
  city          String   @db.VarChar(100)
  state         String   @db.VarChar(100)
  postal_code   String?  @db.VarChar(20)
  country       String   @db.VarChar(100)
  is_default    Boolean  @default(false)
  created_at    DateTime @default(now()) @db.Timestamptz

  user   User    @relation(fields: [user_id], references: [id])
  orders Order[]

  @@map("addresses")
}

// ==========================================
// CATALOG
// ==========================================

model Brand {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  logo_id     String?  @db.Uuid
  description String?  @db.Text
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz

  logo     Media?    @relation("BrandLogo", fields: [logo_id], references: [id])
  products Product[]

  @@map("brands")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  parent_id   String?  @db.Uuid
  name        String   @unique @db.VarChar(255)
  slug        String   @unique @db.VarChar(255)
  image_id    String?  @db.Uuid
  description String?  @db.Text
  is_featured Boolean  @default(false)
  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now()) @db.Timestamptz

  parent   Category?  @relation("ParentChild", fields: [parent_id], references: [id])
  children Category[] @relation("ParentChild")
  image    Media?     @relation("CategoryImage", fields: [image_id], references: [id])
  products Product[]

  @@map("categories")
}

model Product {
  id                String    @id @default(uuid()) @db.Uuid
  brand_id          String?   @db.Uuid
  category_id       String    @db.Uuid
  name              String    @db.VarChar(255)
  slug              String    @unique @db.VarChar(255)
  short_description String?   @db.Text
  description       String?   @db.Text
  is_featured       Boolean   @default(false)
  is_active         Boolean   @default(true)
  is_published      Boolean   @default(false)
  published_at      DateTime? @db.Timestamptz
  created_at        DateTime  @default(now()) @db.Timestamptz
  updated_at        DateTime  @updatedAt @db.Timestamptz

  brand    Brand?           @relation(fields: [brand_id], references: [id])
  category Category         @relation(fields: [category_id], references: [id])
  variants ProductVariant[]
  images   ProductImage[]
  tags     ProductTag[]

  @@map("products")
}

model ProductVariant {
  id                  String   @id @default(uuid()) @db.Uuid
  product_id          String   @db.Uuid
  sku                 String   @unique @db.VarChar(100)
  price               Decimal  @db.Decimal(12, 2)
  compare_price       Decimal? @db.Decimal(12, 2)
  stock_quantity      Int      @default(0)
  low_stock_threshold Int      @default(5)
  weight              Decimal? @db.Decimal(8, 3)
  is_default          Boolean  @default(false)
  is_active           Boolean  @default(true)
  created_at          DateTime @default(now()) @db.Timestamptz

  product    Product            @relation(fields: [product_id], references: [id])
  attributes VariantAttribute[]
  images     ProductImage[]
  orderItems OrderItem[]
  cartItems  CartItem[]
  wishlists  Wishlist[]

  @@map("product_variants")
}

model VariantAttribute {
  id              String   @id @default(uuid()) @db.Uuid
  variant_id      String   @db.Uuid
  attribute_name  String   @db.VarChar(100)
  attribute_value String   @db.VarChar(255)
  created_at      DateTime @default(now()) @db.Timestamptz

  variant ProductVariant @relation(fields: [variant_id], references: [id])

  @@map("variant_attributes")
}

model ProductImage {
  id         String   @id @default(uuid()) @db.Uuid
  product_id String   @db.Uuid
  variant_id String?  @db.Uuid
  media_id   String   @db.Uuid
  alt_text   String?  @db.VarChar(255)
  is_primary Boolean  @default(false)
  sort_order Int      @default(0)
  created_at DateTime @default(now()) @db.Timestamptz

  product Product         @relation(fields: [product_id], references: [id])
  variant ProductVariant? @relation(fields: [variant_id], references: [id])
  media   Media           @relation("ProductImageMedia", fields: [media_id], references: [id])

  @@map("product_images")
}

model ProductTag {
  id         String   @id @default(uuid()) @db.Uuid
  product_id String   @db.Uuid
  tag        String   @db.VarChar(100)
  created_at DateTime @default(now()) @db.Timestamptz

  product Product @relation(fields: [product_id], references: [id])

  @@map("product_tags")
}

// ==========================================
// ORDERS & CHECKOUT
// ==========================================

model Order {
  id                  String        @id @default(uuid()) @db.Uuid
  user_id             String        @db.Uuid
  shipping_address_id String        @db.Uuid
  order_number        String        @unique @db.VarChar(50)
  status              OrderStatus   @default(pending)
  subtotal            Decimal       @db.Decimal(12, 2)
  shipping_fee        Decimal       @db.Decimal(12, 2)
  discount_amount     Decimal       @default(0) @db.Decimal(12, 2)
  tax_amount          Decimal       @default(0) @db.Decimal(12, 2)
  total_amount        Decimal       @db.Decimal(12, 2)
  payment_method      String        @db.VarChar(100)
  payment_status      PaymentStatus @default(pending)
  notes               String?       @db.Text
  created_at          DateTime      @default(now()) @db.Timestamptz
  updated_at          DateTime      @updatedAt @db.Timestamptz

  user             User                 @relation(fields: [user_id], references: [id])
  shipping_address Address              @relation(fields: [shipping_address_id], references: [id])
  items            OrderItem[]
  statusHistories  OrderStatusHistory[]

  @@map("orders")
}

model OrderItem {
  id            String   @id @default(uuid()) @db.Uuid
  order_id      String   @db.Uuid
  variant_id    String   @db.Uuid
  product_name  String   @db.VarChar(255)
  variant_label String?  @db.VarChar(255)
  quantity      Int
  unit_price    Decimal  @db.Decimal(12, 2)
  total_price   Decimal  @db.Decimal(12, 2)
  created_at    DateTime @default(now()) @db.Timestamptz

  order   Order          @relation(fields: [order_id], references: [id])
  variant ProductVariant @relation(fields: [variant_id], references: [id])

  @@map("order_items")
}

model OrderStatusHistory {
  id         String      @id @default(uuid()) @db.Uuid
  order_id   String      @db.Uuid
  status     OrderStatus
  note       String?     @db.Text
  changed_by String?     @db.Uuid
  created_at DateTime    @default(now()) @db.Timestamptz

  order Order @relation(fields: [order_id], references: [id])
  admin User? @relation(fields: [changed_by], references: [id])

  @@map("order_status_history")
}

// ==========================================
// CART & WISHLIST
// ==========================================

model Cart {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String?  @db.Uuid
  session_id String?  @db.VarChar(255)
  expires_at DateTime @db.Timestamptz
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  user  User?      @relation(fields: [user_id], references: [id])
  items CartItem[]

  @@map("carts")
}

model CartItem {
  id         String   @id @default(uuid()) @db.Uuid
  cart_id    String   @db.Uuid
  variant_id String   @db.Uuid
  quantity   Int
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  cart    Cart           @relation(fields: [cart_id], references: [id])
  variant ProductVariant @relation(fields: [variant_id], references: [id])

  @@map("cart_items")
}

model Wishlist {
  id         String   @id @default(uuid()) @db.Uuid
  user_id    String   @db.Uuid
  variant_id String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz

  user    User           @relation(fields: [user_id], references: [id])
  variant ProductVariant @relation(fields: [variant_id], references: [id])

  @@map("wishlists")
}

// ==========================================
// CONTENT & MARKETING
// ==========================================

model Slider {
  id          String    @id @default(uuid()) @db.Uuid
  title       String    @db.VarChar(255)
  image_id    String    @db.Uuid
  link_url    String?   @db.VarChar(500)
  button_text String?   @db.VarChar(100)
  is_active   Boolean   @default(true)
  sort_order  Int       @default(0)
  starts_at   DateTime? @db.Timestamptz
  ends_at     DateTime? @db.Timestamptz
  created_at  DateTime  @default(now()) @db.Timestamptz

  image Media @relation("SliderImage", fields: [image_id], references: [id])

  @@map("sliders")
}

model Banner {
  id         String    @id @default(uuid()) @db.Uuid
  title      String    @db.VarChar(255)
  image_id   String    @db.Uuid
  link_url   String?   @db.VarChar(500)
  position   String    @db.VarChar(100)
  is_active  Boolean   @default(true)
  starts_at  DateTime? @db.Timestamptz
  ends_at    DateTime? @db.Timestamptz
  created_at DateTime  @default(now()) @db.Timestamptz

  image Media @relation("BannerImage", fields: [image_id], references: [id])

  @@map("banners")
}

model Faq {
  id         String   @id @default(uuid()) @db.Uuid
  question   String   @db.VarChar(500)
  answer     String   @db.Text
  category   String   @db.VarChar(100)
  sort_order Int      @default(0)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz

  @@map("faqs")
}

// ==========================================
// MEDIA
// ==========================================

model Media {
  id          String   @id @default(uuid()) @db.Uuid
  file_name   String   @db.VarChar(100)
  file_path   String   @db.VarChar(500)
  url         String   @db.VarChar(100)
  mime_type   String   @db.VarChar(100)
  file_size   Int
  width       Int?
  height      Int?
  alt_text    String?  @db.VarChar(200)
  uploaded_by String?  @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz

  uploader User? @relation("UserMedia", fields: [uploaded_by], references: [id])

  // Relations to other tables that reference Media
  storeProfiles StoreProfile[] @relation("StoreProfileLogo")
  brands        Brand[]        @relation("BrandLogo")
  categories    Category[]     @relation("CategoryImage")
  productImages ProductImage[] @relation("ProductImageMedia")
  sliders       Slider[]       @relation("SliderImage")
  banners       Banner[]       @relation("BannerImage")

  @@map("media")
}
